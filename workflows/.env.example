MISTRAL_API_KEY=
FACT_CHECK_POST_URL=http://localhost:8000/api/stream/fact-check

# UUID of the active broadcast in the facts app (see facts app -> broadcasts table).
# Set this to the UUID generated for the current debate session.
BROADCAST_UUID=
VERISTRAL_POST_URL=http://localhost:8001/api/stream/fact-check
MISTRAL_AGENT_NAME_PREFIX=factcheck-live

# ── Global model fallback (used if no per-agent override is set) ──────────────
# This value is only reached when MISTRAL_MODEL_<AGENT> is unset AND the
# agent definition has no default_model. In practice the per-agent defaults
# in agent_specs.py always apply first, so this is a last-resort safety net.
MISTRAL_AGENT_MODEL=mistral-medium-latest

# ── Per-agent model overrides ─────────────────────────────────────────────────
# Unset = use the default_model defined in agent_specs.py (recommended).
# Override here to pin a specific model per agent without touching code.
#
# Fast tier (ministral-8b-latest) — latency > accuracy:
#MISTRAL_MODEL_CLAIM_EXTRACTOR=ministral-8b-latest
#MISTRAL_MODEL_ROUTEUR=ministral-8b-latest
#MISTRAL_MODEL_RHETORIQUE=ministral-8b-latest
#MISTRAL_MODEL_CORRECTION=ministral-8b-latest
#
# Smart tier (mistral-medium-latest) — balanced accuracy + web search:
#MISTRAL_MODEL_STATISTIQUE=mistral-medium-latest
#MISTRAL_MODEL_COHERENCE=mistral-medium-latest
#MISTRAL_MODEL_CONTEXTE=mistral-medium-latest
#
# Best tier (mistral-large-latest) — final synthesis, accuracy paramount:
#MISTRAL_MODEL_EDITEUR=mistral-large-latest

VIDEO_STREAM_DELAY_SECONDS=30
# Budget for the full analysis pipeline (routeur + up to 4 specialists + editor + web_search).
# 90 s covers p95 latency on mid-tier Mistral deployments.
FACT_CHECK_ANALYSIS_TIMEOUT_SECONDS=90
MISTRAL_RATE_LIMIT_MAX_RETRIES=4
MISTRAL_RATE_LIMIT_BACKOFF_BASE_SECONDS=0.7
MISTRAL_RATE_LIMIT_BACKOFF_MAX_SECONDS=6.0

# ── STT transcript batch pipeline ─────────────────────────────────────────────
# Duration (seconds) of each speech window before flushing to TranscriptBatchWorkflow.
STT_BUFFER_SECONDS=20
# Minimum number of completed sentences to trigger an early flush (whichever comes first).
STT_MIN_SENTENCES=6
# Optional: label the live video source for provenance in fact-check payloads.
SOURCE_VIDEO=
